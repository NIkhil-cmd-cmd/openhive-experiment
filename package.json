{
  "name": "openhive-experiment",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "seed-only": "node --loader ts-node/esm src/seed-cli.ts",
    "bench": "node --loader ts-node/esm src/index.ts",
    "db:up": "docker compose up -d && sleep 3",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d && sleep 3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.78.0",
    "pg": "^8.13.0",
    "uuid": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2"
  }
}
